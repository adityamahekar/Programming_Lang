-- Data Types Reference:
-- ┌─────────────────┬───────────────────────────────────┐
-- │   Data Type     │         Description               │
-- ├─────────────────┼───────────────────────────────────┤
-- │ INT             │ whole numbers (-2B to 2B)         │
-- │ TINYINT         │ small numbers (-128 to 127)       │
-- │ BIGINT          │ very large numbers                │
-- │ FLOAT           │ decimal, less precise             │
-- │ DOUBLE          │ decimal, more precise             │
-- │ DECIMAL(p,s)    │ exact decimal (e.g. money)        │
-- │ BOOL/BOOLEAN    │ 0 = false, 1 = true               │
-- ├─────────────────┼───────────────────────────────────┤
-- │ CHAR(n)         │ fixed length string (max 255)     │
-- │ VARCHAR(n)      │ variable length (max 65,535)      │
-- │ TEXT            │ long text (max 65,535 chars)      │
-- │ LONGTEXT        │ very long text (max 4GB)          │
-- │ ENUM            │ one value from a list             │
-- ├─────────────────┼───────────────────────────────────┤
-- │ DATE            │ YYYY-MM-DD                        │
-- │ TIME            │ HH:MM:SS                          │
-- │ DATETIME        │ YYYY-MM-DD HH:MM:SS               │
-- │ TIMESTAMP       │ auto tracks date/time             │
-- │ YEAR            │ YYYY                              │
-- ├─────────────────┼───────────────────────────────────┤
-- │ BLOB            │ binary data (max 65KB)            │
-- │ LONGBLOB        │ large binary (max 4GB)            │
-- │ JSON            │ stores JSON data                  │
-- └─────────────────┴───────────────────────────────────┘

-------------------------------------------------------------------------------------

UNSIGNED means no negative numbers — only 0 and above, which doubles the positive range!
sql-- Syntax
column_name INT UNSIGNED

