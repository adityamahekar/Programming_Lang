-- DATABASE
-- ====================================
-- CREATE DATABASE college;                        -- create database
-- CREATE DATABASE IF NOT EXISTS Instagram;        -- create only if not exists
-- DROP DATABASE IF EXISTS Instagram;              -- delete database
-- USE Instagram;                                  -- select database

-- ====================================
-- CREATE TABLE
-- ====================================
CREATE TABLE userss (
    id         INT PRIMARY KEY,          -- unique, cant be similar
    age        INT UNSIGNED,             -- only positive numbers
    name       VARCHAR(30) NOT NULL,     -- cant keep empty
    email      VARCHAR(50) UNIQUE,       -- cant add duplicate value
    followers  INT UNSIGNED DEFAULT 0,   -- if nothing added then 0
    CONSTRAINT CHECK (age >= 13)         -- age >= 13 only then add
);

-- ====================================
-- SELECT all data
-- ====================================
SELECT * FROM userss;                    -- fetch all rows from userss


