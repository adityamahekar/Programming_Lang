# ==================== READ + WRITE (r+) ====================
f = open("data.txt", "r+")                 # read + write
print(f.read())                           # read first
f.write("\nAdded using r+")               # write after reading
f.close()


# ==================== WRITE + READ (w+) ====================
f = open("data.txt", "w+")                 # overwrite + read/write
f.write("Fresh Data")                     # overwrite file
f.seek(0)                                 # move cursor to start
print(f.read())                           # read content
f.close()


# ==================== APPEND + READ (a+) ====================
f = open("data.txt", "a+")                 # append + read
f.write("\nAppended Data")                # append
f.seek(0)                                 # move to start
print(f.read())                           # read all
f.close()


# ==================== WITH STATEMENT (BEST PRACTICE) ====================
with open("data.txt", "r") as f:           # auto close
    print(f.read())


# ==================== READ LINE BY LINE ====================
with open("data.txt", "r") as f:
    print(f.readline())                   # read one line
    print(f.readlines())                  # read all lines as list


# ==================== WRITE MULTIPLE LINES ====================
lines = ["Line1\n", "Line2\n", "Line3\n"]

with open("data.txt", "w") as f:
    f.writelines(lines)                   # write list


# ==================== FILE POINTER ====================
with open("data.txt", "r") as f:
    print(f.tell())                       # current position
    f.read(5)                             # read 5 chars
    print(f.tell())                       # updated position
    f.seek(0)                             # move pointer to start


# ==================== CHECK FILE EXISTS ====================
import os

if os.path.exists("data.txt"):            # check existence
    print("File exists")
else:
    print("File not found")


