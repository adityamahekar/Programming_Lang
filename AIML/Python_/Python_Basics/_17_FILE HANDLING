# ==================== BASIC FILE OPEN ====================
f = open("data.txt", "r")                  # open file in read mode
data = f.read()                           # read full content
print(data)
f.close()                                 # close file


# ==================== WRITE MODE (w) ====================
f = open("data.txt", "w")                  # write mode (overwrite)
f.write("Hello Python")                   # write data
f.close()                                 # close file


# ==================== APPEND MODE (a) ====================
f = open("data.txt", "a")                  # append mode
f.write("\nNew Line Added")               # adds at end
f.close()


# ==================== READ MODE (r) ====================
f = open("data.txt", "r")                  # read mode
print(f.read())                           # read entire file
f.close()


